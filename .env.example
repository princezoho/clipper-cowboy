# Clipper Cowboy — environment variables
# All values are optional. The first-run wizard will write to this file
# (well, to .env) once you point the app at a folder, so most users never
# need to edit this by hand.

# Project folder. Source videos live at the root, exported clips land in
# clips/, the character library in characters/. Defaults to ~/ClipCataloger
# if unset. The first-run wizard will set this for you.
PROJECT_DIR=

# OpenAI API key. Enables AI auto-fill (clip name + description + tags) and
# character recognition. Leave blank to use the app without AI features —
# you can still clip, tag, and export manually. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Port for the production single-process server (npm start / launcher).
# 47474 is chosen because it's unlikely to collide with anything else
# you might be running. Pick something else if you have a clash.
PORT=47474

# Optional Stem Studio connection. Point this at a clone of
# https://github.com/wassermanproductions/stem-studio after building its MCP
# server. No hosted AI key is required; separation runs locally.
CLIPPER_STEM_STUDIO_ROOT=

# Optional overrides. Clipper automatically reuses Stem Studio's macOS app
# environment when present, otherwise Stem Studio defaults to <root>/.venv.
CLIPPER_STEM_STUDIO_PYTHON=
CLIPPER_STEM_STUDIO_CACHE=

# Long local jobs are stopped after this many minutes (default: 360).
CLIPPER_STEMS_TIMEOUT_MINUTES=360

# Security: the server deliberately binds to 127.0.0.1. Do not expose it via
# a tunnel or reverse proxy; its filesystem APIs are designed for local use.
